APP_NAME=Manuscript Studio
APP_ENV=production
APP_SECRET_KEY=replace-with-a-random-secret
APP_ALLOWED_HOSTS=your-domain.com
ADMIN_EMAILS=admin@example.com
DATABASE_URL=sqlite:///./data/app.db
LOG_LEVEL=INFO
SESSION_COOKIE_NAME=ms_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_MAX_AGE=1209600
CSRF_ENABLED=true
HSTS_ENABLED=true
MAX_UPLOAD_MB=10
SIGNUP_BONUS_CENTS=0
ENABLE_PAYMENTS=false
ENABLE_MOCK_TOPUP=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_REQUESTS=12
RATE_LIMIT_AUTH_WINDOW_SECONDS=300
PAYMENT_PROVIDER=mock

REVIEW_PRICE_PER_1K_CHARS_CENTS=69
REWRITE_PRICE_PER_1K_CHARS_CENTS=199

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_REVIEW_MODEL=qwen-plus
QWEN_REWRITE_MODEL=qwen-max

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_REVIEW_MODEL=deepseek-chat
DEEPSEEK_REWRITE_MODEL=deepseek-chat

ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_RETURN_URL=https://your-domain/payments/return
ALIPAY_NOTIFY_URL=https://your-domain/payments/callback/alipay

WECHAT_MCHID=
WECHAT_PRIVATE_KEY=
WECHAT_CERT_SERIAL_NO=
WECHAT_APPID=
WECHAT_APIV3_KEY=
WECHAT_NOTIFY_URL=https://your-domain/payments/callback/wechat
WECHAT_PUBLIC_KEY=
WECHAT_PUBLIC_KEY_ID=
